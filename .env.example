# ─── Firebase ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Super Admin ───────────────────────────────────────────────────────────────
# Email address that gets unrestricted super-admin access on first login
VITE_SUPER_ADMIN_EMAIL=

# ─── AI (server-side only — set in Vercel dashboard, NOT prefixed with VITE_) ─
# Used by /api/ai serverless function. Never exposed to the browser.
ANTHROPIC_API_KEY=          # Claude (default for all AI features)
OPENAI_API_KEY=             # GPT-4o (pass model: 'gpt-4o' in InvokeLLM calls)

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API endpoints
ALLOWED_ORIGINS=https://hubcys.com,https://www.hubcys.com

# ─── Framework update checker (/api/check-nist-updates) ───────────────────────
# Vercel sets CRON_SECRET automatically for cron jobs. Also used for manual GET calls:
#   GET /api/check-nist-updates?secret=<CRON_SECRET>
CRON_SECRET=

# Last NIST SP 800-53 version that has been reviewed and applied to the codebase.
# The quarterly cron alerts you if NIST publishes a newer version.
# Update this value in Vercel dashboard after applying each new release to the code.
NIST_800_53_KNOWN_VERSION=5.2.0

# Optional: Slack / Teams / Discord / generic webhook URL for update notifications.
# Payload is Slack Block Kit compatible (also works with most webhook receivers).
# Leave empty to log only (still visible in Vercel Functions tab).
FRAMEWORK_UPDATE_WEBHOOK_URL=
