# ─── Firebase ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Super Admin ───────────────────────────────────────────────────────────────
# Email address that gets unrestricted super-admin access on first login
VITE_SUPER_ADMIN_EMAIL=

# ─── AI (server-side only — set in Vercel dashboard, NOT prefixed with VITE_) ─
# Used by /api/ai serverless function. Never exposed to the browser.
ANTHROPIC_API_KEY=          # Claude (default for all AI features)
OPENAI_API_KEY=             # GPT-4o (pass model: 'gpt-4o' in InvokeLLM calls)
